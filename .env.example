# NexusTech Environment Variables - Port 7788

# Application
NODE_ENV=development
PORT=5000
API_PORT=7788
FRONTEND_PORT=7788

# Database (mapped to 27018 to avoid conflicts)
MONGO_USER=nexus_admin
MONGO_PASSWORD=your_secure_password
MONGO_DATABASE=nexustech
MONGO_PORT=27018

# Security
JWT_SECRET=your_super_secret_jwt_key_32_chars_minimum
JWT_EXPIRE=7d
BCRYPT_ROUNDS=12

# URLs - All use port 7788
API_URL=http://localhost:7788/api
FRONTEND_URL=http://localhost:7788
WEBSITE_URL=http://localhost:7788
ADMIN_URL=http://localhost:7788/admin
CORS_ORIGIN=http://localhost:7788

# Upload
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
